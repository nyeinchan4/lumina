# ─── Node / npm ───────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─── Frontend build ───────────────────────────────────────────
frontend/dist/
frontend/dist-ssr/
frontend/.env
frontend/*.local

# ─── Backend ──────────────────────────────────────────────────
backend/.env
backend/dist/

# ─── Environment files (keep .example and .docker) ────────────
