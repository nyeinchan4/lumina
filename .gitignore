*.tfstate
*.tfstate.backup
*.tfstate.lock.info
*.tfplan
tfplan
terraform/temp/
terraform/DEV/variables.tfvars
terraform/**/.terraform.lock.hcl

# ─── SSH keys ─────────────────────────────────────────────────
*.pem
*.key
!*.key.example

# ─── Docker ───────────────────────────────────────────────────
.docker/

# ─── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

